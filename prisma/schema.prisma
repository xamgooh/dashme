generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id           String    @id @default(cuid())
  url          String    @unique
  propertyUrl  String
  displayName  String?
  accountEmail String?
  active       Boolean   @default(true)
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  lastSynced   DateTime?
  color        String    @default("#818cf8")
  createdAt    DateTime  @default(now())
  metrics      SiteMetric[]
  pages        SitePage[]
  keywords     SiteKeyword[]
  countries    SiteCountry[]
}

model SiteMetric {
  id          String   @id @default(cuid())
  siteId      String
  date        DateTime @db.Date
  clicks      Int
  impressions Int
  ctr         Float
  position    Float
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@unique([siteId, date])
  @@index([siteId, date])
}

model SitePage {
  id          String   @id @default(cuid())
  siteId      String
  pageUrl     String
  clicks      Int
  impressions Int
  ctr         Float
  position    Float
  trendPct    Float    @default(0)
  syncedAt    DateTime @default(now())
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@index([siteId, clicks])
}

model SiteKeyword {
  id          String   @id @default(cuid())
  siteId      String
  keyword     String
  clicks      Int
  impressions Int
  ctr         Float
  position    Float
  syncedAt    DateTime @default(now())
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@index([siteId, clicks])
}

model SiteCountry {
  id          String   @id @default(cuid())
  siteId      String
  country     String
  clicks      Int
  impressions Int
  ctr         Float
  position    Float
  syncedAt    DateTime @default(now())
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@index([siteId, clicks])
}
