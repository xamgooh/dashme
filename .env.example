# PostgreSQL — copy from Railway dashboard
DATABASE_URL="postgresql://user:password@host:5432/dashme"

# Google OAuth — från Google Cloud Console
# Authorized redirect URI: https://your-app.railway.app/api/auth/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://your-app.railway.app/api/auth/callback"

# Dashboard auth — välj ett starkt lösenord
DASHBOARD_SECRET="byt-ut-detta-till-nagot-starkt"

# Exponeras till klienten för Connect-knappen
NEXT_PUBLIC_DASHBOARD_SECRET="byt-ut-detta-till-nagot-starkt"
